# Database
DATABASE_URL=postgresql+asyncpg://transcriber:transcriber@postgres:5432/transcriber
DATABASE_URL_SYNC=postgresql+psycopg2://transcriber:transcriber@postgres:5432/transcriber
POSTGRES_USER=transcriber
POSTGRES_PASSWORD=transcriber
POSTGRES_DB=transcriber

# Redis
REDIS_URL=redis://redis:6379/0

# Claude API
ANTHROPIC_API_KEY=sk-ant-your-key-here

# API authentication key (leave empty to disable auth — dev mode only)
# Set a long random string for network-accessible deployments: openssl rand -hex 32
API_KEY=

# Worker mode: "native" (macOS Metal) or "docker" (CPU via faster-whisper)
WORKER_MODE=docker
# Transcription engine: "mlx" (Apple Silicon) or "faster-whisper" (CPU)
TRANSCRIPTION_ENGINE=faster-whisper

# Whisper — legacy (faster-whisper / Docker)
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Whisper — MLX models (native macOS)
WHISPER_MODEL=mlx-community/whisper-large-v3-turbo
WHISPER_DETECT_MODEL=mlx-community/whisper-tiny
# Language: "auto" = detect via tiny model, or force e.g. "en"
WHISPER_LANGUAGE=auto

# HuggingFace (for pyannote diarization)
HF_TOKEN=

# Pipeline toggles
DIARIZATION_ENABLED=false
TRANSCRIPT_CLEANUP_ENABLED=false

# LLM cleanup model
CLEANUP_MODEL=claude-haiku-4-20250514

# Per-video transcription time limit (videos longer than this are rejected)
MAX_VIDEO_DURATION_MINUTES=120

# Daily LLM spend cap in USD (set to 0 to disable)
DAILY_LLM_BUDGET_USD=5.0

# App
APP_ENV=development
LOG_LEVEL=INFO
AUDIO_DIR=/data/audio
MODEL_CACHE_DIR=/data/models
